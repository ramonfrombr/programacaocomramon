# =============================================================================
# E2E test environment — copy to `.env.test` and fill in real values.
#
#   cp .env.test.example .env.test
#
# Never commit `.env.test` (it contains secrets). This example file is safe
# to commit; it documents every variable Playwright E2E needs locally and in CI.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=test
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Use english for predictable test URLs: /sign-in, /courses, /watch-course
NEXT_PUBLIC_LANGUAGE=english

# -----------------------------------------------------------------------------
# Clerk — dedicated Development or test instance (not production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Playwright auth setup reads these; create matching users in Clerk Dashboard
E2E_CLERK_STUDENT_EMAIL=
E2E_CLERK_STUDENT_PASSWORD=
E2E_CLERK_TEACHER_EMAIL=
E2E_CLERK_TEACHER_PASSWORD=

# Teacher gate — must equal the Clerk userId of the teacher test user (see setup below)
NEXT_PUBLIC_TEACHER_ID=

# -----------------------------------------------------------------------------
# Database — MongoDB Atlas test cluster (isolated from dev/prod)
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Third-party services — dummy values are fine; E2E does not exercise checkout,
# Mux playback, or UploadThing uploads. Valid-looking formats avoid build errors.
# -----------------------------------------------------------------------------
UPLOADTHING_SECRET=dummy
UPLOADTHING_APP_ID=dummy
MUX_TOKEN_ID=dummy
MUX_TOKEN_SECRET=dummy
STRIPE_API_KEY_DEV=sk_test_dummy
STRIPE_API_KEY_PROD=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy
MP_ACCESS_TOKEN=dummy

# Optional — only needed if tests hit the landing hero video embed
NEXT_PUBLIC_LANDING_PAGE_VIDEO_URL=dQw4w9WgXcQ

# =============================================================================
# One-time setup: Clerk
# =============================================================================
#
# 1. Create a dedicated Clerk instance (Development mode is fine) for E2E only.
#    Do not reuse production credentials.
#
# 2. Enable Clerk testing tokens for the instance:
#    https://clerk.com/docs/guides/development/testing/overview
#
# 3. In Clerk Dashboard → Users, create two test users:
#      - Student: email/password matching E2E_CLERK_STUDENT_* above
#      - Teacher: email/password matching E2E_CLERK_TEACHER_* above
#
# 4. Copy API keys into NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY and CLERK_SECRET_KEY.
#
# 5. Open the teacher user in Clerk Dashboard and copy their userId (e.g.
#    user_2abc...) into NEXT_PUBLIC_TEACHER_ID. The teacher E2E setup fails
#    loudly if this does not match — teacher routes gate on lib/teacher.ts.
#
# Playwright uses @clerk/testing (clerkSetup + clerk.signIn) per:
# https://clerk.com/docs/guides/development/testing/playwright/overview
#
# =============================================================================
# One-time setup: MongoDB Atlas
# =============================================================================
#
# 1. On your Atlas project, create a separate database for E2E, e.g.:
#      programacaocomramon-e2e
#    Use a dedicated cluster or a separate DB name on an existing dev cluster.
#    The E2E suite resets this database on every run (disposable by design).
#
# 2. Create a database user with read/write access to that database.
#
# 3. Allow network access from your IP (local) and 0.0.0.0/0 or GitHub Actions
#    IP ranges (CI). Restrict in production-like Atlas projects if possible.
#
# 4. Copy the MongoDB connection string into DATABASE_URL in `.env.test`.
#    Example format:
#      mongodb+srv://<user>:<password>@<cluster>.mongodb.net/programacaocomramon-e2e?retryWrites=true&w=majority
#
# 5. Reset and seed before a local run:
#      npm run db:e2e:reset
#
# =============================================================================
# GitHub Actions secrets (map to the same values as `.env.test`)
# =============================================================================
#
# Create these repository secrets for the E2E workflow:
#
#   E2E_DATABASE_URL              → DATABASE_URL
#   E2E_CLERK_SECRET_KEY          → CLERK_SECRET_KEY
#   E2E_CLERK_PUBLISHABLE_KEY     → NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
#   E2E_CLERK_STUDENT_EMAIL       → E2E_CLERK_STUDENT_EMAIL
#   E2E_CLERK_STUDENT_PASSWORD    → E2E_CLERK_STUDENT_PASSWORD
#   E2E_CLERK_TEACHER_EMAIL       → E2E_CLERK_TEACHER_EMAIL
#   E2E_CLERK_TEACHER_PASSWORD    → E2E_CLERK_TEACHER_PASSWORD
#   E2E_TEACHER_ID                → NEXT_PUBLIC_TEACHER_ID
#
# Dummy third-party keys can be inlined in the workflow; they are listed above.
#
# =============================================================================
# Local workflow
# =============================================================================
#
#   cp .env.test.example .env.test   # fill in values
#   npm run db:e2e:reset             # reset Atlas test DB + seed fixtures
#   npm run test:e2e                 # headless full run
#   npm run test:e2e:ui              # interactive debugging
#
# With reuseExistingServer, you can run `npm run dev` separately for faster
# iteration; Playwright will attach to the running server on :3000.
